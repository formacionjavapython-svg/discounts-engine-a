<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC "-//Puppy Crawl//DTD Check Configuration 1.3//EN" "http://www.puppycrawl.com">

<module name="Checker">
    <property name="severity" value="warning"/>

    <module name="TreeWalker">
        
        <!-- 1. Indentación: 4 espacios -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
            <property name="throwsIndent" value="4"/>
            <property name="lineWrappingIndentation" value="4"/>
            <property name="arrayInitIndent" value="4"/>
        </module>

        <!-- 2. Nombres de clases en PascalCase -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 3. Constantes en UPPER_CASE (static final) -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>
        
        <!-- Reglas básicas adicionales recomendadas -->
        <module name="MemberName"/> <!-- camelCase para variables de miembro -->
        <module name="MethodName"/> <!-- camelCase para métodos -->
        <module name="PackageName"/> <!-- minúsculas, puntos permitidos -->
        <module name="ParameterName"/> <!-- camelCase para parámetros -->
        <module name="LocalVariableName"/> <!-- camelCase para variables locales -->
        
        <!-- Whitespace -->
        <module name="WhitespaceAfter"/>
        <module name="WhitespaceAround"/>
        <module name="NoWhitespaceAfter"/>
        
        <!-- Imports -->
        <module name="AvoidStarImport"/>
        <module name="UnusedImports"/>
        
    </module>
</module>

